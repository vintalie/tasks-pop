# URL base da API (obrigatório no build de produção com subdomínios)
# Em dev: não defina - o Vite proxy usa /api -> localhost:8000
# Produção: defina antes de npm run build
# VITE_API_URL=https://taskspop-api.dcmmarketingdigital.com.br/api

# Pusher (atualização em tempo real da lista - opcional)
# VITE_PUSHER_APP_KEY=
# VITE_PUSHER_APP_CLUSTER=mt1
